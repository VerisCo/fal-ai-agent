# fal-image-agent — environment template. Copy to .env and fill in.
#   cp .env.example .env
# .env is gitignored. On Render, set these in the service's Environment tab.

# --- Required ---

# fal.ai API key from https://fal.ai/dashboard/keys
FAL_KEY=

# --- Auth for the standalone /invoke and /chat endpoints ---

# Static API key callers must send as `Authorization: Bearer <key>`.
# Render's render.yaml generates one automatically; set your own here for
# local use, or leave unset to fall back to Commands.com JWT verification.
AGENT_API_KEY=

# --- Optional overrides ---

# fal.ai model to run (any text-to-image model id on fal.run).
# FAL_MODEL=fal-ai/flux/schnell
# Output size: square_hd, square, portrait_4_3, portrait_16_9, landscape_4_3, landscape_16_9
# FAL_IMAGE_SIZE=landscape_4_3
# Comma-separated CORS allowlist for browser callers (default: allow all).
# CORS_ORIGINS=
# AGENT_ID=alphapoint.fal-image-agent
# AGENT_NAME=fal-image-agent
# AGENT_DESCRIPTION=Generates images from text prompts via fal.ai and returns the image URL

# --- Veris marketplace gateway (optional; off by default) ---
# Connect this agent to a Veris gateway instead of / in addition to the
# standalone HTTP endpoints. See README for details.
# CONNECTION_MODE=gateway          # http (default) | gateway | both
# GATEWAY_TRANSPORT=http           # ws | http (http needs AGENT_PUBLIC_URL)
# GATEWAY_URL=
# AGENT_CONNECT_TOKEN=             # third-party: per-agent token from the operator
# GATEWAY_ADMIN_TOKEN=             # first-party: gateway admin token (never share)
# AGENT_PUBLIC_URL=                # e.g. https://fal-image-agent.onrender.com
# GATEWAY_SIGNING_SECRET=          # auto-claimed on boot; set only to pin
# AGENT_VISIBILITY=public          # public | unlisted | private
# AGENT_REGISTER_STATUS=active     # active | draft

# --- Local development only (uncomment for `npm run dev`) ---
# PORT is injected by Render automatically — do NOT set it there.
# PORT=3000
# NODE_ENV=development
# SKIP_AUTH=true                   # dev-only: skips auth on /invoke and /chat
